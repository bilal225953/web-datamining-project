<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/ai-kb.owl"
         xmlns="http://example.org/ai-kb.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/ai-kb.owl"/>

<owl:ObjectProperty rdf:about="#affiliatedWith">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Organization"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#developedBy">
  <rdfs:domain rdf:resource="#Model"/>
  <rdfs:range rdf:resource="#Organization"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contributedTo">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Model"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#AIConcept">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="#AIConcept"/>
</owl:Class>

<owl:Class rdf:about="#Organization">
  <rdfs:subClassOf rdf:resource="#AIConcept"/>
</owl:Class>

<owl:Class rdf:about="#Model">
  <rdfs:subClassOf rdf:resource="#AIConcept"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Geoffrey_Hinton">
  <rdf:type rdf:resource="#Person"/>
  <affiliatedWith rdf:resource="#Google"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Yann_LeCun">
  <rdf:type rdf:resource="#Person"/>
  <affiliatedWith rdf:resource="#Meta_AI"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Yoshua_Bengio">
  <rdf:type rdf:resource="#Person"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Google">
  <rdf:type rdf:resource="#Organization"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#DeepMind">
  <rdf:type rdf:resource="#Organization"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Meta_AI">
  <rdf:type rdf:resource="#Organization"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#BERT">
  <rdf:type rdf:resource="#Model"/>
  <developedBy rdf:resource="#Google"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#AlphaGo">
  <rdf:type rdf:resource="#Model"/>
  <developedBy rdf:resource="#DeepMind"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#LLaMA">
  <rdf:type rdf:resource="#Model"/>
  <developedBy rdf:resource="#Meta_AI"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#p"/>

<swrl:Variable rdf:about="urn:swrl#o"/>

<swrl:Variable rdf:about="urn:swrl#m"/>

<owl:AllDifferent>
  <owl:distinctMembers rdf:parseType="Collection">
    <rdf:Description rdf:about="#Geoffrey_Hinton"/>
    <rdf:Description rdf:about="#Yann_LeCun"/>
    <rdf:Description rdf:about="#Yoshua_Bengio"/>
    <rdf:Description rdf:about="#Google"/>
    <rdf:Description rdf:about="#DeepMind"/>
    <rdf:Description rdf:about="#Meta_AI"/>
    <rdf:Description rdf:about="#BERT"/>
    <rdf:Description rdf:about="#AlphaGo"/>
    <rdf:Description rdf:about="#LLaMA"/>
  </owl:distinctMembers>
</owl:AllDifferent>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="urn:swrl#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:ClassAtom>
              <swrl:classPredicate rdf:resource="#Organization"/>
              <swrl:argument1 rdf:resource="urn:swrl#o"/>
            </swrl:ClassAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:ClassAtom>
                  <swrl:classPredicate rdf:resource="#Model"/>
                  <swrl:argument1 rdf:resource="urn:swrl#m"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#affiliatedWith"/>
                      <swrl:argument1 rdf:resource="urn:swrl#p"/>
                      <swrl:argument2 rdf:resource="urn:swrl#o"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <rdf:Description>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="#developedBy"/>
                          <swrl:argument1 rdf:resource="urn:swrl#m"/>
                          <swrl:argument2 rdf:resource="urn:swrl#o"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                  </rdf:rest>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#contributedTo"/>
          <swrl:argument1 rdf:resource="urn:swrl#p"/>
          <swrl:argument2 rdf:resource="urn:swrl#m"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
